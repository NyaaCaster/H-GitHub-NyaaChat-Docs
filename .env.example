# NyaaChat-Docs environment configuration — TEMPLATE
# Copy to `.env` and fill in real values.

# === GitHub Personal Access Token ===
# Used by macmini for `git pull` content updates.
# Generate at: https://github.com/settings/tokens
# Required scopes: repo (private repos) or public_repo (public repos)
GITHUB_PAT=

# === NyaaDockerHUB private registry ===
# Windows (build+push): localhost:5000
# macmini (deploy+pull): 192.168.31.142:5000
PRIVATE_DOCKER_REGISTRY_HOST=

# Private registry HTTP API base URL (for tag cleanup). Defaults to http://<HOST> if unset.
# PRIVATE_DOCKER_REGISTRY_URL=
